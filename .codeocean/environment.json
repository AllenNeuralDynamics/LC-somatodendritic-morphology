{
	"version": 1,
	"base_image": "codeocean/mambaforge3:23.1.0-4-python3.10.12-ubuntu22.04",
	"post_install": true,
	"options": {
		"registry_host_arg": true,
		"git_ask_pass": true,
		"mount_secrets": true
	},
	"installers": {
		"pip": {
			"packages": [
				{
					"name": "allensdk",
					"version": "2.16.2"
				},
				{
					"name": "brainrender",
					"version": "2.1.16"
				},
				{
					"name": "k3d",
					"version": "2.17.0"
				},
				{
					"name": "matplotlib",
					"version": "3.10.8"
				},
				{
					"name": "neuron-morphology",
					"version": "1.2.2"
				},
				{
					"name": "pandas",
					"version": "1.5.3"
				},
				{
					"name": "s3fs",
					"version": "2026.2.0"
				},
				{
					"name": "scikit-image",
					"version": "0.24.0"
				},
				{
					"name": "scipy",
					"version": "1.10.1"
				},
				{
					"name": "zarr",
					"version": "2.18.2"
				}
			],
			"options": {
				"upgrade_strategy": "only-if-needed"
			},
			"pre_install_options": {}
		}
	}
}